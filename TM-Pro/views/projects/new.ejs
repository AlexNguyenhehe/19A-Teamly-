<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="container" style="padding-top:2rem;padding-bottom:4rem">
  <div style="max-width:600px;margin:0 auto">
    <div class="page-header">
      <h1 class="page-title">🚀 Tạo dự án mới</h1>
      <p class="text-dim">Bạn sẽ tự động trở thành nhóm trưởng</p>
    </div>
    <% if (flash) { %><div class="flash flash-<%= flashType %>"><%= flashType==='success'?'✅':'⚠️' %> <%= flash %></div><% } %>
    <div class="card card-glow-cyan">
      <form action="/projects/new" method="POST">
        <div class="form-group">
          <label class="form-label">Tên dự án *</label>
          <input type="text" name="name" class="form-control" placeholder="VD: Đồ án Kỹ Năng Mềm Nhóm 3..." required/>
        </div>
        <div class="form-group">
          <label class="form-label">Mô tả dự án</label>
          <textarea name="description" class="form-control" placeholder="Mô tả ngắn về dự án..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Deadline dự án</label>
          <input type="date" name="deadline" class="form-control"/>
        </div>

        <!-- Project template (Pro) -->
        <div class="form-group">
          <label class="form-label">
            Mẫu dự án (tự tạo sẵn nhiệm vụ & lộ trình)
            <% if (!currentUser.isPro) { %><span class="badge-pro" style="margin-left:6px">⭐ PRO</span><% } %>
          </label>
          <% if (currentUser.isPro) { %>
            <select name="template" class="form-control">
              <option value="">-- Không dùng mẫu --</option>
              <% (locals.templates||[]).forEach(t => { %>
                <option value="<%= t.id %>"><%= t.name %></option>
              <% }) %>
            </select>
            <p style="font-size:0.78rem;color:var(--text-dim);margin-top:0.4rem">
              Chọn mẫu sẽ tự tạo danh sách nhiệm vụ và lộ trình mẫu cho dự án.
            </p>
          <% } else { %>
            <select class="form-control" disabled>
              <option>-- Nâng cấp Pro để dùng mẫu dự án --</option>
            </select>
            <p style="font-size:0.78rem;color:var(--text-dim);margin-top:0.4rem">
              Gói Pro có sẵn mẫu: 💻 Đồ án CNTT, 📋 Báo cáo thực tập, 🎓 Khóa luận tốt nghiệp.
              <a href="/pricing" style="color:var(--yellow)">Xem chi tiết →</a>
            </p>
          <% } %>
        </div>

        <button type="submit" class="btn btn-cyan btn-block btn-lg">⚡ Tạo dự án</button>
      </form>
    </div>
    <div style="text-align:center;margin-top:1rem"><a href="/projects/join" class="text-dim">Hoặc tham gia bằng mã mời →</a></div>
  </div>
</div>
<%- include('../partials/footer') %>
