<%- include('../partials/header') %>
<%- include('../partials/navbar', {notifications:[], unreadCount: notifCount}) %>

<script>
  window.PROJECT_ID = <%= project.id %>;
  window.CURRENT_USER_ID = <%= currentUser ? currentUser.id : 'null' %>;
</script>

<div class="container" style="padding-top:1.5rem;padding-bottom:4rem">
  <% if (flash) { %><div class="flash flash-<%= flashType %>"><%= flashType==='success'?'✅':'⚠️' %> <%= flash %></div><% } %>

  <!-- Project header -->
  <div class="d-flex align-center justify-between mb-2" style="flex-wrap:wrap;gap:0.8rem">
    <div>
      <div style="display:flex;align-items:center;gap:0.8rem;flex-wrap:wrap">
        <h1 style="font-size:1.5rem;color:var(--cyan);text-shadow:var(--glow-cyan)"><%= project.name %></h1>
        <% if (project.status === 'completed') { %>
          <span class="badge badge-green">✅ Hoàn thành</span>
        <% } else if (project.status === 'archived') { %>
          <span class="badge badge-dim">📦 Lưu trữ</span>
        <% } else { %>
          <span class="badge badge-cyan">🟢 Đang chạy</span>
        <% } %>
        <% if (memberInfo) { %>
          <% const rl = {leader:'👑 Nhóm trưởng',vice_leader:'⭐ Phó nhóm',member:'👤 Thành viên'}; %>
          <span class="badge <%= {leader:'badge-cyan',vice_leader:'badge-purple',member:'badge-dim',custom:'badge-pink'}[memberInfo.role]||'badge-dim' %>">
            <%= memberInfo.role==='custom'&&memberInfo.custom_role_name ? `🎯 ${memberInfo.custom_role_name}` : (rl[memberInfo.role]||memberInfo.role) %>
          </span>
        <% } %>
      </div>
      <% if (project.description) { %><p style="color:var(--text-dim);font-size:0.9rem;margin-top:0.2rem"><%= project.description %></p><% } %>
    </div>
    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
      <% if (project.deadline) { %>
        <span style="font-size:0.85rem;color:var(--text-dim)">📅 <%= new Date(project.deadline).toLocaleDateString('vi-VN') %></span>
      <% } %>
      <% if (canManage) { %><a href="/projects/<%= project.id %>?tab=settings" class="btn btn-ghost btn-sm">⚙️ Cài đặt</a><% } %>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <% const tabs = [
      {id:'overview',  label:'📊 Tổng quan'},
      {id:'tasks',     label:'📋 Nhiệm vụ'},
      {id:'kanban',    label:'🗂️ Kanban'},
      {id:'stats',     label:'📈 Thống kê'},
      {id:'members',   label:'👥 Thành viên'},
      {id:'roadmap',   label:'🗺️ Lộ trình'},
      {id:'chat',      label:'💬 Chat nhóm'},
      {id:'settings',  label:'⚙️ Cài đặt', hidden: !canManage}
    ]; %>
    <% tabs.forEach(t => { %>
      <% if (!t.hidden) { %>
        <a href="/projects/<%= project.id %>?tab=<%= t.id %>" class="tab-btn <%= tab===t.id?'active':'' %>"><%= t.label %></a>
      <% } %>
    <% }) %>
  </div>

  <!-- ═══════ OVERVIEW TAB ═══════ -->
  <% if (tab === 'overview') { %>
    <div class="fade-in">
      <div class="stats-grid">
        <div class="stat-card s-cyan">
          <div class="stat-number"><%= stats.totalTasks %></div>
          <div class="stat-label">Tổng nhiệm vụ</div>
        </div>
        <div class="stat-card s-green">
          <div class="stat-number"><%= stats.doneTasks %></div>
          <div class="stat-label">Hoàn thành</div>
        </div>
        <div class="stat-card s-pink">
          <div class="stat-number"><%= stats.memberCount %></div>
          <div class="stat-label">Thành viên</div>
        </div>
        <div class="stat-card s-yellow">
          <div class="stat-number"><%= stats.overdueTasks %></div>
          <div class="stat-label">Trễ hạn</div>
        </div>
      </div>
      <!-- Progress -->
      <div class="card mb-3">
        <div class="card-header"><span class="card-title">📊 Tiến độ dự án</span><span style="color:var(--cyan);font-family:'Orbitron',sans-serif"><%= stats.progress %>%</span></div>
        <div class="progress-wrap" style="height:18px"><div class="progress-fill" data-pct="<%= stats.progress %>" style="width:0"></div></div>
        <p style="color:var(--text-dim);font-size:0.82rem;margin-top:0.6rem"><%= stats.doneTasks %> / <%= stats.totalTasks %> nhiệm vụ hoàn thành</p>
      </div>

      <!-- Export report -->
      <div class="card mb-3">
        <div class="card-header"><span class="card-title">📄 Xuất báo cáo</span><% if (!currentUser.isPro) { %><span class="badge-pro">⭐ PRO</span><% } %></div>
        <% if (currentUser.isPro) { %>
          <div style="display:flex;gap:0.6rem;flex-wrap:wrap">
            <a href="/projects/<%= project.id %>/export/pdf" class="btn btn-cyan btn-sm">📕 Xuất PDF</a>
            <a href="/projects/<%= project.id %>/export/excel" class="btn btn-green btn-sm" style="color:var(--green);border-color:var(--green)">📗 Xuất Excel</a>
          </div>
        <% } else { %>
          <p style="color:var(--text-dim);font-size:0.85rem">Nâng cấp lên <strong style="color:var(--yellow)">Pro</strong> để xuất báo cáo tổng kết dạng PDF/Excel.</p>
          <a href="/pricing" class="btn btn-ghost btn-sm" style="color:var(--yellow);border-color:var(--yellow)">⭐ Xem gói Pro</a>
        <% } %>
      </div>
      <!-- My Tasks quick view -->
      <% if (locals.myTasks && myTasks.length > 0) { %>
        <div class="card mb-3">
          <div class="card-header"><span class="card-title">📋 Nhiệm vụ của tôi</span><a href="/projects/<%= project.id %>?tab=tasks" class="btn btn-ghost btn-sm">Xem tất cả</a></div>
          <% myTasks.slice(0,4).forEach(t => { %>
            <div class="task-item priority-<%= t.priority %>" style="margin-bottom:0.5rem">
              <div class="d-flex align-center justify-between">
                <span style="font-weight:600"><%= t.title %></span>
                <% const statusBadge = {todo:'badge-dim',in_progress:'badge-cyan',submitted:'badge-yellow',approved:'badge-green',rejected:'badge-red'}; %>
                <span class="badge <%= statusBadge[t.status]||'badge-dim' %>">
                  <%= {todo:'Chưa làm',in_progress:'Đang làm',submitted:'Đã nộp',approved:'✅ Duyệt',rejected:'❌ Từ chối'}[t.status] %>
                </span>
              </div>
              <% if (t.deadline) { %><div style="font-size:0.8rem" data-deadline="<%= t.deadline %>"></div><% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
      <!-- Activity log -->
      <div class="card">
        <div class="card-header"><span class="card-title">📜 Hoạt động gần đây</span></div>
        <% if (!locals.recentActivity || recentActivity.length === 0) { %>
          <p class="text-dim text-small">Chưa có hoạt động</p>
        <% } else { %>
          <% recentActivity.forEach(a => { %>
            <div style="display:flex;gap:0.8rem;padding:0.5rem 0;border-bottom:1px solid rgba(0,245,255,0.05);font-size:0.85rem">
              <span style="color:var(--text-dim);white-space:nowrap"><%= new Date(a.created_at).toLocaleString('vi-VN',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit'}) %></span>
              <span style="color:var(--cyan)">·</span>
              <span style="color:var(--text-bright)"><%= a.display_name || 'Hệ thống' %></span>
              <span class="text-dim"><%= a.detail %></span>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  <!-- ═══════ TASKS TAB ═══════ -->
  <% } else if (tab === 'tasks') { %>
    <div class="fade-in">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;flex-wrap:wrap;gap:0.5rem">
        <h3 style="color:var(--cyan);font-size:1rem">Danh sách nhiệm vụ (<%= (locals.tasks||[]).length %>)</h3>
        <% if (canManage) { %>
          <button class="btn btn-cyan" data-modal-open="modalCreateTask">＋ Thêm nhiệm vụ</button>
        <% } %>
      </div>

      <!-- Filter pills -->
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem">
        <button class="btn btn-ghost btn-sm task-filter active" data-filter="all">Tất cả</button>
        <button class="btn btn-ghost btn-sm task-filter" data-filter="todo">Chưa làm</button>
        <button class="btn btn-ghost btn-sm task-filter" data-filter="in_progress">Đang làm</button>
        <button class="btn btn-ghost btn-sm task-filter" data-filter="submitted">Đã nộp</button>
        <button class="btn btn-ghost btn-sm task-filter" data-filter="approved">Hoàn thành</button>
      </div>

      <% if (!locals.tasks || tasks.length === 0) { %>
        <div class="empty-state"><div class="empty-state-icon">📋</div><p>Chưa có nhiệm vụ nào</p></div>
      <% } else { %>
        <% tasks.forEach(t => {
          const isOverdue = t.deadline && new Date(t.deadline) < new Date() && t.status !== 'approved';
          const isMyTask = currentUser && (t.assigned_to === null || t.assigned_to === currentUser.id);
          const mySubStatus = t.my_submission_status;
        %>
          <div class="task-item priority-<%= t.priority %>" data-status="<%= t.status %>">
            <div class="d-flex align-center justify-between" style="flex-wrap:wrap;gap:0.5rem">
              <div>
                <span style="font-weight:700;color:var(--text-bright)"><%= t.title %></span>
                <% if (t.assignee_name) { %><span style="font-size:0.8rem;color:var(--text-dim)"> → 👤 <%= t.assignee_name %></span><% } %>
              </div>
              <div style="display:flex;gap:0.4rem;flex-wrap:wrap">
                <% const prBadge = {urgent:'badge-red',high:'badge-pink',medium:'badge-yellow',low:'badge-dim'}; %>
                <span class="badge <%= prBadge[t.priority] %>"><%= {urgent:'🔴',high:'🟠',medium:'🟡',low:'⚪'}[t.priority] %> <%= t.priority %></span>
                <% const stBadge = {todo:'badge-dim',in_progress:'badge-cyan',submitted:'badge-yellow',approved:'badge-green',rejected:'badge-red'}; %>
                <span class="badge <%= stBadge[t.status] %>"><%= {todo:'Chưa làm',in_progress:'Đang làm',submitted:'📨 Đã nộp',approved:'✅ Xong',rejected:'❌ Từ chối'}[t.status] %></span>
              </div>
            </div>
            <% if (t.description) { %><p style="font-size:0.85rem;color:var(--text-dim);margin-top:0.3rem"><%= t.description %></p><% } %>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:0.5rem;flex-wrap:wrap;gap:0.5rem">
              <div style="font-size:0.8rem;color:var(--text-dim)">
                <% if (t.deadline) { %><span data-deadline="<%= t.deadline %>"></span><% } %>
              </div>
              <div style="display:flex;gap:0.4rem">
                <!-- Member: submit drive link -->
                <% if (isMyTask && t.status !== 'approved' && !mySubStatus) { %>
                  <button class="btn btn-cyan btn-sm" onclick="openSubmitModal(<%= t.id %>,'<%= escHtml(t.title) %>')">📤 Nộp bài</button>
                <% } %>
                <% if (mySubStatus === 'pending') { %><span class="badge badge-yellow">⏳ Chờ duyệt</span><% } %>
                <!-- Leader: review submissions -->
                <% if (canManage && t.status === 'submitted') { %>
                  <button class="btn btn-green btn-sm" onclick="openReviewModal(<%= t.id %>,'<%= escHtml(t.title) %>')">🔍 Duyệt</button>
                <% } %>
                <% if (canManage) { %>
                  <form action="/projects/<%= project.id %>/tasks/<%= t.id %>/delete" method="POST" style="display:inline">
                    <button type="submit" class="btn btn-red btn-sm" data-confirm="Xóa nhiệm vụ '<%= t.title %>'?">🗑️</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

  <!-- ═══════ KANBAN TAB (Pro) ═══════ -->
  <% } else if (tab === 'kanban') { %>
    <div class="fade-in">
      <% if (!currentUser.isPro) { %>
        <div class="pro-lock">
          <div class="pro-lock-icon">🗂️</div>
          <h3>Kanban Board — Tính năng Pro</h3>
          <p>Kéo thả nhiệm vụ giữa các cột "Cần làm / Đang làm / Hoàn thành" để quản lý công việc trực quan hơn.</p>
          <a href="/pricing" class="btn btn-cyan">⭐ Nâng cấp lên Pro</a>
        </div>
      <% } else { %>
        <% 
          const kTasks = locals.tasks || [];
          const kCols = [
            { key: 'todo', label: '📝 Cần làm' },
            { key: 'in_progress', label: '🔄 Đang làm' },
            { key: 'approved', label: '✅ Hoàn thành' }
          ];
          const mapStatusToCol = (s) => {
            if (s === 'approved') return 'approved';
            if (s === 'todo' || s === 'rejected') return 'todo';
            return 'in_progress'; // in_progress, submitted
          };
          const prBadge2 = {urgent:'badge-red',high:'badge-pink',medium:'badge-yellow',low:'badge-dim'};
        %>
        <p style="color:var(--text-dim);font-size:0.85rem;margin-bottom:1rem">💡 Kéo thẻ nhiệm vụ giữa các cột để cập nhật trạng thái.</p>
        <div class="kanban-board">
          <% kCols.forEach(col => {
            const colTasks = kTasks.filter(t => mapStatusToCol(t.status) === col.key);
          %>
            <div class="kanban-col" data-status="<%= col.key %>">
              <div class="kanban-col-header">
                <span><%= col.label %></span>
                <span class="kanban-count"><%= colTasks.length %></span>
              </div>
              <% if (colTasks.length === 0) { %>
                <div class="kanban-empty">Không có nhiệm vụ</div>
              <% } %>
              <% colTasks.forEach(t => { %>
                <div class="kanban-card priority-<%= t.priority %>" draggable="true" data-task-id="<%= t.id %>">
                  <div class="kanban-card-title"><%= t.title %></div>
                  <div class="kanban-card-meta">
                    <span class="badge <%= prBadge2[t.priority]||'badge-dim' %>"><%= t.priority %></span>
                    <% if (t.assignee_name) { %><span>👤 <%= t.assignee_name %></span><% } %>
                    <% if (t.deadline) { %><span>📅 <%= new Date(t.deadline).toLocaleDateString('vi-VN') %></span><% } %>
                    <% if (t.status === 'submitted') { %><span class="badge badge-yellow">⏳ Chờ duyệt</span><% } %>
                    <% if (t.status === 'rejected') { %><span class="badge badge-red">❌ Từ chối</span><% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  <!-- ═══════ STATS TAB (Pro) ═══════ -->
  <% } else if (tab === 'stats') { %>
    <div class="fade-in">
      <% if (!currentUser.isPro) { %>
        <div class="pro-lock">
          <div class="pro-lock-icon">📈</div>
          <h3>Thống kê đóng góp — Tính năng Pro</h3>
          <p>Xem biểu đồ radar so sánh điểm số, tỉ lệ hoàn thành, đúng hạn và khối lượng công việc giữa các thành viên.</p>
          <a href="/pricing" class="btn btn-cyan">⭐ Nâng cấp lên Pro</a>
        </div>
      <% } else { %>
        <% const mStats = locals.memberStats || []; %>
        <% if (mStats.length === 0) { %>
          <div class="empty-state"><div class="empty-state-icon">📈</div><p>Chưa có dữ liệu thành viên</p></div>
        <% } else { %>
          <div class="card mb-3">
            <div class="card-header"><span class="card-title">📈 So sánh đóng góp thành viên</span></div>
            <div class="radar-wrap">
              <canvas id="memberRadarChart" height="320"></canvas>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><span class="card-title">📋 Chi tiết theo thành viên</span></div>
            <% mStats.forEach(m => { %>
              <div class="member-row">
                <div class="avatar" style="background:<%= m.avatarColor %>"><%= (m.displayName||'?')[0].toUpperCase() %></div>
                <div class="member-info" style="flex:1">
                  <div class="member-name"><%= m.displayName %></div>
                  <div class="member-sub">
                    <%= m.doneCount %>/<%= m.assignedCount %> nhiệm vụ hoàn thành ·
                    Đúng hạn <%= m.ontimeRate %>% ·
                    <% if (m.overdueCount > 0) { %><span style="color:var(--red)">Trễ hạn <%= m.overdueCount %></span><% } else { %>Không trễ hạn<% } %>
                  </div>
                </div>
                <div class="score-display" style="min-width:48px;text-align:center"><%= m.score %>⭐</div>
              </div>
            <% }) %>
          </div>

          <script>
            (function() {
              const data = <%- JSON.stringify(mStats) %>;
              const ctx = document.getElementById('memberRadarChart');
              if (!ctx || !window.Chart) return;
              const colors = ['#00f5ff','#ff00cc','#9600ff','#00ff88','#ffcc00','#ff6600'];
              new Chart(ctx, {
                type: 'radar',
                data: {
                  labels: ['Điểm số', 'Tỉ lệ hoàn thành', 'Đúng hạn', 'Khối lượng việc', 'Hoạt động'],
                  datasets: data.map((m, i) => ({
                    label: m.displayName,
                    data: [
                      Math.min(100, (m.score || 0) * 10),
                      m.completionRate,
                      m.ontimeRate,
                      m.workloadIndex,
                      m.activityIndex
                    ],
                    borderColor: colors[i % colors.length],
                    backgroundColor: colors[i % colors.length] + '33',
                    borderWidth: 2,
                    pointBackgroundColor: colors[i % colors.length]
                  }))
                },
                options: {
                  responsive: true,
                  scales: {
                    r: {
                      angleLines: { color: 'rgba(128,128,160,0.2)' },
                      grid: { color: 'rgba(128,128,160,0.2)' },
                      pointLabels: { color: getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#c0c0e0', font: { size: 11 } },
                      ticks: { display: false, beginAtZero: true, max: 100 }
                    }
                  },
                  plugins: {
                    legend: { labels: { color: getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#c0c0e0' } }
                  }
                }
              });
            })();
          </script>
        <% } %>
      <% } %>
    </div>

  <!-- ═══════ MEMBERS TAB ═══════ -->
  <% } else if (tab === 'members') { %>
    <div class="fade-in">
      <!-- Pending approvals -->
      <% if (canManage && locals.pendingMembers && pendingMembers.length > 0) { %>
        <div class="card card-glow-pink mb-3">
          <div class="card-header"><span class="card-title" style="color:var(--pink)">⏳ Yêu cầu tham gia (<%= pendingMembers.length %>)</span></div>
          <% pendingMembers.forEach(pm => { %>
            <div class="member-row">
              <div class="avatar" style="background:<%= pm.avatar_color %>"><%= (pm.display_name||pm.username)[0].toUpperCase() %></div>
              <div class="member-info">
                <div class="member-name"><%= pm.display_name %></div>
                <div class="member-sub">@<%= pm.username %></div>
              </div>
              <div style="display:flex;gap:0.4rem">
                <form action="/projects/<%= project.id %>/members/<%= pm.user_id %>/approve" method="POST">
                  <button class="btn btn-green btn-sm">✅ Duyệt</button>
                </form>
                <form action="/projects/<%= project.id %>/members/<%= pm.user_id %>/reject" method="POST">
                  <button class="btn btn-red btn-sm">❌ Từ chối</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Active members -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">👥 Thành viên (<%= (locals.members||[]).filter(m=>m.status==='active').length %>)</span>
          <!-- Invite code -->
          <div style="display:flex;align-items:center;gap:0.5rem">
            <span style="font-size:0.8rem;color:var(--text-dim)">Mã mời:</span>
            <span class="invite-code-box" style="font-size:0.95rem"><%= project.invite_code %></span>
            <button class="copy-btn" onclick="copyText('<%= project.invite_code %>', this)" title="Sao chép mã">📋</button>
          </div>
        </div>
        <% (locals.members||[]).filter(m=>m.status==='active').forEach(m => { %>
          <div class="member-row">
            <div class="avatar" style="background:<%= m.avatar_color %>"><%= (m.display_name||m.username)[0].toUpperCase() %></div>
            <div class="member-info" style="flex:1">
              <div class="member-name"><%= m.display_name %> <% if (m.user_id === project.owner_id) { %><span style="color:var(--yellow)">⭐</span><% } %></div>
              <div class="member-sub">@<%= m.username %><% if (m.email) { %> · <%= m.email %><% } %></div>
            </div>
            <% const roleLabel2 = {leader:'👑 Nhóm trưởng',vice_leader:'⭐ Phó nhóm',member:'👤 Thành viên'}; %>
            <span class="badge <%= {leader:'badge-cyan',vice_leader:'badge-purple',member:'badge-dim',custom:'badge-pink'}[m.role]||'badge-dim' %>">
              <%= m.role==='custom'&&m.custom_role_name ? `🎯 ${m.custom_role_name}` : (roleLabel2[m.role]||m.role) %>
            </span>
            <div class="score-display" style="min-width:48px;text-align:center"><%= m.score %>⭐</div>
            <% if (canManage && m.user_id !== currentUser.id) { %>
              <button class="btn btn-ghost btn-sm" onclick="openMemberModal(<%= JSON.stringify(m) %>)">✏️</button>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>

  <!-- ═══════ ROADMAP TAB ═══════ -->
  <% } else if (tab === 'roadmap') { %>
    <div class="fade-in">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.5rem">
        <h3 style="color:var(--cyan)">🗺️ Lộ trình dự án</h3>
        <% if (canManage) { %>
          <button class="btn btn-cyan" data-modal-open="modalCreateRoadmap">＋ Thêm mốc</button>
        <% } %>
      </div>

      <% if (!locals.roadmapItems || roadmapItems.length === 0) { %>
        <div class="empty-state"><div class="empty-state-icon">🗺️</div><p>Chưa có mốc lộ trình nào</p></div>
      <% } else { %>
        <!-- Gantt Chart -->
        <div class="card mb-3">
          <div class="card-header"><span class="card-title">📊 Biểu đồ Gantt</span></div>
          <div class="gantt-container">
            <% roadmapItems.forEach(r => { %>
              <div class="gantt-row">
                <div class="gantt-label">
                  <div style="font-weight:600;font-size:0.85rem;color:var(--text-bright)"><%= r.title.substring(0,20) %></div>
                  <div style="font-size:0.72rem;color:var(--text-dim)"><%= new Date(r.start_date).toLocaleDateString('vi-VN') %> → <%= new Date(r.end_date).toLocaleDateString('vi-VN') %></div>
                </div>
                <div class="gantt-track">
                  <div class="gantt-bar" 
                    data-start="<%= r.start_date %>" 
                    data-end="<%= r.end_date %>" 
                    data-color="<%= r.color %>">
                    <%= r.title.substring(0,16) %>
                  </div>
                </div>
                <span class="badge <%= {pending:'badge-dim',in_progress:'badge-cyan',done:'badge-green'}[r.status] %>">
                  <%= {pending:'Chờ',in_progress:'Đang chạy',done:'✅ Xong'}[r.status] %>
                </span>
                <% if (canManage) { %>
                  <form action="/projects/<%= project.id %>/roadmap/<%= r.id %>/delete" method="POST">
                    <button type="submit" class="btn btn-red btn-sm">🗑️</button>
                  </form>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Roadmap list -->
        <% roadmapItems.forEach(r => { %>
          <div class="card mb-2" style="border-left:3px solid <%= r.color %>">
            <div class="d-flex align-center justify-between" style="flex-wrap:wrap;gap:0.5rem">
              <div>
                <span style="font-weight:700;color:var(--text-bright)"><%= r.title %></span>
                <% if (r.assignee_name) { %><span style="color:var(--text-dim);font-size:0.82rem"> · 👤 <%= r.assignee_name %></span><% } %>
              </div>
              <div style="display:flex;gap:0.5rem;align-items:center">
                <span class="badge <%= {pending:'badge-dim',in_progress:'badge-cyan',done:'badge-green'}[r.status] %>">
                  <%= {pending:'⏳ Chờ',in_progress:'🔄 Đang chạy',done:'✅ Xong'}[r.status] %>
                </span>
                <% if (canManage) { %>
                  <form action="/projects/<%= project.id %>/roadmap/<%= r.id %>/status" method="POST" style="display:inline">
                    <select name="status" onchange="this.form.submit()" class="form-control" style="height:30px;padding:2px 6px;font-size:0.8rem;width:auto">
                      <option value="pending" <%=r.status==='pending'?'selected':''%>>⏳ Chờ</option>
                      <option value="in_progress" <%=r.status==='in_progress'?'selected':''%>>🔄 Đang chạy</option>
                      <option value="done" <%=r.status==='done'?'selected':''%>>✅ Xong</option>
                    </select>
                  </form>
                <% } %>
              </div>
            </div>
            <% if (r.description) { %><p style="font-size:0.85rem;color:var(--text-dim);margin-top:0.3rem"><%= r.description %></p><% } %>
            <div style="font-size:0.8rem;color:var(--text-dim);margin-top:0.4rem">
              📅 <%= new Date(r.start_date).toLocaleDateString('vi-VN') %> → <%= new Date(r.end_date).toLocaleDateString('vi-VN') %>
              (<%
                const diffDays = Math.ceil((new Date(r.end_date) - new Date(r.start_date)) / 86400000);
              %><%= diffDays %> ngày)
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

  <!-- ═══════ CHAT TAB ═══════ -->
  <% } else if (tab === 'chat') { %>
    <div class="fade-in">
      <div class="card card-glow-cyan">
        <div class="card-header">
          <span class="card-title">💬 Chat nhóm · <%= project.name %></span>
          <span style="font-size:0.78rem;color:var(--green)">🟢 Trực tuyến</span>
        </div>
        <div class="chat-box" id="chatBox">
          <% if (!locals.messages || messages.length === 0) { %>
            <div style="text-align:center;padding:2rem;color:var(--text-dim);font-size:0.9rem">
              💬 Chưa có tin nhắn nào. Hãy bắt đầu trò chuyện!
            </div>
          <% } else { %>
            <% messages.forEach(m => { %>
              <% const isOwn = m.user_id === currentUser.id; %>
              <% const initial = (m.display_name||'?')[0].toUpperCase(); %>
              <% const time = new Date(m.created_at).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}); %>
              <div class="chat-msg <%= isOwn?'own':'' %>">
                <div class="avatar" style="background:<%= m.avatar_color||'#00f5ff' %>;min-width:30px"><%= initial %></div>
                <div>
                  <% if (!isOwn) { %><div class="chat-name"><%= m.display_name %></div><% } %>
                  <div class="chat-bubble"><%= m.content %></div>
                  <div class="chat-time"><%= time %></div>
