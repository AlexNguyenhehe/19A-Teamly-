              </div>
            <% }) %>
          <% } %>
        </div>
        <div class="typing-indicator" id="typingIndicator"></div>
        <div class="chat-input-area">
          <textarea id="chatInput" class="form-control" placeholder="Nhập tin nhắn... (Enter để gửi)" rows="1"></textarea>
          <button id="chatSendBtn" class="btn btn-cyan" style="padding:0.5rem 1rem">➤ Gửi</button>
        </div>
      </div>
    </div>

  <!-- ═══════ SETTINGS TAB ═══════ -->
  <% } else if (tab === 'settings' && canManage) { %>
    <div class="fade-in" style="max-width:700px">
      <!-- Project settings form -->
      <div class="card mb-3">
        <div class="card-header"><span class="card-title">⚙️ Cài đặt dự án</span></div>
        <form action="/projects/<%= project.id %>/settings/update" method="POST">
          <div class="form-group">
            <label class="form-label">Tên dự án *</label>
            <input type="text" name="name" class="form-control" value="<%= project.name %>" required/>
          </div>
          <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea name="description" class="form-control"><%= project.description||'' %></textarea>
          </div>
          <div class="grid-2">
            <div class="form-group">
              <label class="form-label">Deadline dự án</label>
              <input type="date" name="deadline" class="form-control" value="<%= project.deadline ? new Date(project.deadline).toISOString().split('T')[0] : '' %>"/>
            </div>
            <div class="form-group">
              <label class="form-label">Cảnh báo trước (ngày)</label>
