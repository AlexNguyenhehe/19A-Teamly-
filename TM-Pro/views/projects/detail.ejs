    <form action="/projects/<%= project.id %>/members/${m.user_id}/remove" method="POST">
      <button type="submit" class="btn btn-red btn-sm" data-confirm="Xóa thành viên ${escHtml(m.display_name)} khỏi dự án?">🗑️ Xóa khỏi nhóm</button>
    </form>`;
