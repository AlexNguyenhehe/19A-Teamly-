      <!-- Invite code -->
      <div class="card mb-3">
        <div class="card-header"><span class="card-title">🔑 Mã mời dự án</span></div>
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
          <div class="invite-code-box"><%= project.invite_code %></div>
