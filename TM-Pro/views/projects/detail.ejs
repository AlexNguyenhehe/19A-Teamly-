      <div class="custom-role-input mt-1" data-uid="${m.user_id}" style="display:${m.role==='custom'?'block':'none'}">
        <input type="text" name="custom_role_name" class="form-control" placeholder="Tên vai trò..." value="${escHtml(m.custom_role_name||'')}"/>
      </div>
      <button type="submit" class="btn btn-cyan btn-sm mt-1">Lưu vai trò</button>
