            </div>
          </div>
          <div class="grid-2">
            <div class="form-group">
              <label class="form-label">Trạng thái</label>
              <select name="status" class="form-control">
                <option value="active" <%=project.status==='active'?'selected':''%>>🟢 Đang chạy</option>
                <option value="completed" <%=project.status==='completed'?'selected':''%>>✅ Hoàn thành</option>
                <option value="archived" <%=project.status==='archived'?'selected':''%>>📦 Lưu trữ</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Màu chủ đề</label>
              <input type="color" name="color" class="form-control" value="<%= project.color || '#00f5ff' %>" style="height:44px;padding:4px"/>
            </div>
