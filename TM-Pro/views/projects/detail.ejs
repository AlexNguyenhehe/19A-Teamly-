<script>
function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// Submit task modal
function openSubmitModal(taskId, taskTitle) {
  document.getElementById('submitTaskTitle').textContent = taskTitle;
  document.getElementById('submitTaskForm').action = '/projects/<%= project.id %>/tasks/' + taskId + '/submit';
  openModal('modalSubmitTask');
}

// Review modal — fetch submission from server via simple approach
function openReviewModal(taskId, taskTitle) {
  document.getElementById('reviewTaskTitle').textContent = taskTitle;
  document.getElementById('reviewTaskForm').action = '/projects/<%= project.id %>/tasks/' + taskId + '/review';
  // Fetch latest submission
  fetch('/api/submissions/' + taskId)
    .then(r => r.json())
    .then(data => {
      if (data.submission) {
        const s = data.submission;
        document.getElementById('reviewSubmissionId').value = s.id;
        document.getElementById('reviewContent').innerHTML = `
          <div style="background:rgba(0,245,255,0.05);border:1px solid rgba(0,245,255,0.2);border-radius:8px;padding:1rem;margin-bottom:1rem">
            <div style="font-size:0.82rem;color:var(--text-dim);margin-bottom:0.4rem">🔗 Link Drive:</div>
            <a href="${escHtml(s.drive_link)}" target="_blank" class="btn btn-cyan btn-sm">Mở tài liệu ↗</a>
            ${s.note ? `<div style="margin-top:0.5rem;font-size:0.85rem;color:var(--text-dim)">Ghi chú: ${escHtml(s.note)}</div>` : ''}
            <div style="font-size:0.78rem;color:var(--text-dim);margin-top:0.4rem">Nộp lúc: ${new Date(s.submitted_at).toLocaleString('vi-VN')}</div>
          </div>`;
      } else {
        document.getElementById('reviewContent').innerHTML = '<p style="color:var(--text-dim)">Không tìm thấy bài nộp.</p>';
      }
    });
  openModal('modalReview');
}

// Member edit modal
