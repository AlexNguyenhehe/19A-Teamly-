<%- include('partials/header') %>
<%- include('partials/navbar') %>
<div class="container" style="padding-top:2rem;padding-bottom:4rem">
  <div style="max-width:560px;margin:0 auto">
    <div class="page-header">
      <h1 class="page-title">👤 Hồ sơ cá nhân</h1>
    </div>
    <% if (locals.flash) { %><div class="flash flash-<%= flashType %>"><%= flashType==='success'?'✅':'⚠️' %> <%= flash %></div><% } %>

    <!-- Avatar preview -->
    <div class="card card-glow-cyan mb-3" style="text-align:center;padding:2rem">
      <div class="avatar avatar-xl" style="background:<%= profileUser.avatar_color %>;margin:0 auto 1rem">
        <%= (profileUser.display_name||profileUser.username)[0].toUpperCase() %>
      </div>
      <h2 style="color:var(--text-bright)"><%= profileUser.display_name %></h2>
      <p class="text-dim">@<%= profileUser.username %></p>
      <p class="text-dim text-small mt-1">Tham gia: <%= new Date(profileUser.created_at).toLocaleDateString('vi-VN') %></p>
      <div style="margin-top:0.6rem">
        <% if (currentUser.isPro) { %><span class="badge-pro">⭐ PRO</span><% } else { %><span class="badge-free">FREE</span><% } %>
      </div>
    </div>

    <!-- Plan / Pro -->
    <div class="card mb-3">
      <div class="card-header"><span class="card-title">💎 Gói sử dụng</span></div>
      <% if (currentUser.isPro) { %>
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:0.8rem">Bạn đang sử dụng gói <span class="badge-pro">⭐ PRO</span> — đã mở khóa Kanban, Thống kê, Xuất báo cáo, Mẫu dự án & tùy biến chủ đề.</p>
        <% if (profileUser.role !== 'admin') { %>
          <form action="/profile/upgrade" method="POST">
            <button type="submit" class="btn btn-ghost btn-sm">Chuyển về gói Free</button>
          </form>
        <% } %>
      <% } else { %>
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:0.8rem">Bạn đang dùng gói <span class="badge-free">FREE</span>. Nâng cấp Pro để mở khóa Kanban board, thống kê radar, xuất báo cáo PDF/Excel, mẫu dự án và tùy biến màu chủ đề.</p>
        <div style="display:flex;gap:0.6rem;flex-wrap:wrap">
          <a href="/pricing" class="btn btn-ghost btn-sm">Xem chi tiết</a>
          <form action="/profile/upgrade" method="POST">
            <button type="submit" class="btn btn-cyan btn-sm">⭐ Nâng cấp lên Pro (Demo)</button>
          </form>
        </div>
      <% } %>
    </div>

    <!-- Theme & accent -->
    <div class="card mb-3">
      <div class="card-header"><span class="card-title">🎨 Giao diện</span></div>
      <div class="form-group">
        <label class="form-label">Chế độ hiển thị</label>
        <div style="display:flex;gap:0.6rem">
          <button type="button" class="btn btn-ghost btn-sm" id="setThemeDark">🌙 Tối</button>
          <button type="button" class="btn btn-ghost btn-sm" id="setThemeLight">☀️ Sáng</button>
        </div>
      </div>
      <% if (currentUser.isPro) { %>
        <form action="/profile/accent" method="POST">
          <div class="form-group">
            <label class="form-label">Màu chủ đề riêng (Pro)</label>
            <div style="display:flex;gap:0.8rem;align-items:center">
              <input type="color" name="accent_color" class="form-control" value="<%= profileUser.accent_color || '#00f5ff' %>" style="height:44px;width:80px;padding:4px"/>
              <button type="submit" class="btn btn-cyan btn-sm">💾 Lưu màu</button>
            </div>
          </div>
        </form>
      <% } else { %>
        <p style="font-size:0.82rem;color:var(--text-dim)">
          <span class="badge-pro">⭐ PRO</span> Tùy biến màu chủ đề riêng cho tài khoản của bạn.
          <a href="/pricing" style="color:var(--yellow)">Nâng cấp →</a>
        </p>
      <% } %>
    </div>
    <script>
      document.getElementById('setThemeDark').addEventListener('click', () => setTheme('dark'));
      document.getElementById('setThemeLight').addEventListener('click', () => setTheme('light'));
      function setTheme(t) {
        document.documentElement.setAttribute('data-theme', t);
        fetch('/profile/theme', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({theme:t}) }).catch(()=>{});
      }
    </script>

    <!-- Edit form -->
    <div class="card">
      <div class="card-header"><span class="card-title">✏️ Chỉnh sửa hồ sơ</span></div>
      <form action="/profile/update" method="POST">
        <div class="form-group">
          <label class="form-label">Tên hiển thị</label>
          <input type="text" name="display_name" class="form-control" value="<%= profileUser.display_name||'' %>" required/>
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" value="<%= profileUser.email||'' %>"/>
        </div>
        <div class="form-group">
          <label class="form-label">Màu avatar</label>
          <div style="display:flex;gap:0.8rem;align-items:center;flex-wrap:wrap">
            <% ['#00f5ff','#ff00cc','#9600ff','#00ff88','#ffcc00','#ff6600','#00aaff','#ff3366'].forEach(c => { %>
              <label style="cursor:pointer">
                <input type="radio" name="avatar_color" value="<%= c %>" <%=profileUser.avatar_color===c?'checked':''%> style="display:none" class="color-radio"/>
                <div class="avatar" style="background:<%= c %>;width:36px;height:36px;font-size:0.8rem;transition:all 0.2s;border:2px solid <%=profileUser.avatar_color===c?'white':'transparent'%>" 
                     onclick="this.style.border='2px solid white';document.querySelectorAll('.color-swatch').forEach(s=>s.style.border='2px solid transparent');this.style.border='2px solid white'">
                  <%= (profileUser.display_name||'U')[0].toUpperCase() %>
                </div>
              </label>
            <% }) %>
          </div>
        </div>
        <button type="submit" class="btn btn-cyan btn-block">💾 Lưu thay đổi</button>
      </form>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
