<%- include('partials/header') %>
<%- include('partials/navbar', {notifications, unreadCount}) %>

<div class="container" style="padding-top:2rem;padding-bottom:4rem">
  <% if (flash) { %><div class="flash flash-<%= flashType %>"><%= flash === 'success' ? '✅' : '⚠️' %> <%= flash %></div><% } %>

  <!-- Header -->
  <div class="d-flex align-center justify-between mb-3">
    <div>
      <h1 style="color:var(--cyan);text-shadow:var(--glow-cyan);margin-bottom:0.2rem">
        Xin chào, <span style="color:var(--pink);text-shadow:var(--glow-pink)"><%= currentUser.displayName %></span> ⚡
      </h1>
      <p class="text-dim">Đây là tổng quan hoạt động của bạn hôm nay</p>
    </div>
    <div style="display:flex;gap:0.6rem">
      <a href="/projects/new" class="btn btn-cyan">＋ Tạo dự án</a>
      <a href="/projects/join" class="btn btn-ghost">🔗 Tham gia</a>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-grid mb-3">
    <div class="stat-card s-cyan">
      <div class="stat-number"><%= myProjects.length %></div>
      <div class="stat-label">Dự án tham gia</div>
    </div>
    <div class="stat-card s-pink">
      <div class="stat-number"><%= pendingTasks.length %></div>
      <div class="stat-label">Nhiệm vụ đang làm</div>
    </div>
    <div class="stat-card s-yellow">
      <div class="stat-number"><%= deadlineWarnings.length %></div>
      <div class="stat-label">Sắp đến hạn</div>
    </div>
    <div class="stat-card s-green">
      <div class="stat-number"><%= unreadCount %></div>
      <div class="stat-label">Thông báo mới</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start">
    <!-- Left: Projects -->
    <div>
      <!-- Deadline warnings -->
      <% if (deadlineWarnings.length > 0) { %>
        <div class="card card-glow-pink mb-3">
          <div class="card-header">
            <span class="card-title" style="color:var(--red)">⚠️ SẮP TỚI HẠN</span>
          </div>
          <% deadlineWarnings.forEach(t => { %>
            <div style="display:flex;align-items:center;gap:0.8rem;padding:0.5rem 0;border-bottom:1px solid rgba(255,34,68,0.1)">
              <span style="font-size:1.1rem">📋</span>
              <div style="flex:1">
                <div style="font-weight:600;color:var(--text-bright)"><%= t.title %></div>
                <div style="font-size:0.8rem;color:var(--text-dim)">📁 <%= t.project_name %></div>
              </div>
              <div data-deadline="<%= t.deadline %>"></div>
              <a href="/projects/<%= t.project_id %>?tab=tasks" class="btn btn-red btn-sm">Xem</a>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- My Projects -->
      <h2 style="font-size:1rem;color:var(--cyan);letter-spacing:0.1em;margin-bottom:1rem;text-transform:uppercase;font-family:'Orbitron',sans-serif">
        📁 Dự án của tôi (<%= myProjects.length %>)
      </h2>
      <% if (myProjects.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">🚀</div>
          <p style="font-size:1rem;color:var(--text-dim);margin-bottom:1rem">Bạn chưa tham gia dự án nào</p>
          <a href="/projects/new" class="btn btn-cyan">Tạo dự án đầu tiên</a>
        </div>
      <% } else { %>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem">
          <% myProjects.forEach(p => {
            const progress = p.task_count > 0 ? Math.round((p.done_count / p.task_count) * 100) : 0;
            const isOverdue = p.deadline && new Date(p.deadline) < new Date() && p.status !== 'completed';
            const roleLabel = {leader:'👑 Nhóm trưởng',vice_leader:'⭐ Phó nhóm',member:'👤 Thành viên',custom:`🎯 ${p.custom_role_name||''}`}[p.role] || p.role;
          %>
            <a href="/projects/<%= p.id %>" class="project-card">
              <div style="display:flex;align-items:flex-start;justify-content:space-between">
                <div style="font-family:'Orbitron',sans-serif;font-size:0.95rem;color:var(--text-bright);font-weight:700"><%= p.name %></div>
                <% if (p.status === 'completed') { %>
                  <span class="badge badge-green">✅ Xong</span>
                <% } else if (isOverdue) { %>
                  <span class="badge badge-red">⚠️ Trễ</span>
                <% } else { %>
                  <span class="badge badge-cyan">🟢 Đang chạy</span>
                <% } %>
              </div>
              <% if (p.description) { %>
                <p style="font-size:0.82rem;color:var(--text-dim);line-height:1.5"><%= p.description.substring(0,80) %><%= p.description.length>80?'...':'' %></p>
              <% } %>
              <!-- Progress -->
              <div>
                <div style="display:flex;justify-content:space-between;font-size:0.78rem;margin-bottom:4px">
                  <span class="text-dim">Tiến độ</span>
                  <span style="color:var(--cyan)"><%= progress %>%</span>
                </div>
                <div class="progress-wrap"><div class="progress-fill" data-pct="<%= progress %>" style="width:0"></div></div>
              </div>
              <div class="project-card-meta">
                <span>👥 <%= p.member_count %></span>
                <span>📋 <%= p.done_count %>/<%= p.task_count %> xong</span>
                <% if (p.deadline) { %><span>📅 <%= new Date(p.deadline).toLocaleDateString('vi-VN') %></span><% } %>
              </div>
              <span class="badge <%= {leader:'badge-cyan',vice_leader:'badge-purple',member:'badge-dim',custom:'badge-pink'}[p.role]||'badge-dim' %>" style="width:fit-content"><%= roleLabel %></span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <!-- My pending tasks -->
      <% if (pendingTasks.length > 0) { %>
        <h2 style="font-size:1rem;color:var(--cyan);letter-spacing:0.1em;margin:2rem 0 1rem;text-transform:uppercase;font-family:'Orbitron',sans-serif">
          📋 Nhiệm vụ cần làm
        </h2>
        <% pendingTasks.forEach(t => { %>
          <div class="task-item priority-<%= t.priority %>">
            <div class="d-flex align-center justify-between">
              <div style="font-weight:600;color:var(--text-bright)"><%= t.title %></div>
              <div style="display:flex;gap:0.5rem;align-items:center">
                <span class="badge <%= {urgent:'badge-red',high:'badge-pink',medium:'badge-yellow',low:'badge-dim'}[t.priority] %>">
                  <%= {urgent:'🔴 Khẩn',high:'🟠 Cao',medium:'🟡 TB',low:'⚪ Thấp'}[t.priority] %>
                </span>
                <a href="/projects/<%= t.project_id %>?tab=tasks" class="btn btn-cyan btn-sm">Xem</a>
              </div>
            </div>
            <div style="font-size:0.82rem;color:var(--text-dim);margin-top:4px">
              📁 <%= t.project_name %>
              <% if (t.deadline) { %> · <span data-deadline="<%= t.deadline %>"></span><% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- Right: Notifications -->
    <div>
      <div class="card card-glow-cyan" style="position:sticky;top:80px">
        <div class="card-header">
          <span class="card-title">🔔 Thông báo gần đây</span>
          <form action="/notifications/read-all" method="POST">
            <button type="submit" class="btn btn-ghost btn-sm">Đọc hết</button>
          </form>
        </div>
        <% if (notifications.length === 0) { %>
          <div class="empty-state" style="padding:1.5rem">
            <div style="font-size:2rem;margin-bottom:0.5rem">🔕</div>
            <p style="font-size:0.85rem;color:var(--text-dim)">Chưa có thông báo nào</p>
          </div>
        <% } else { %>
          <% notifications.slice(0,12).forEach(n => { %>
            <div class="notif-item <%= n.is_read?'':'unread' %>" data-id="<%= n.id %>" 
                 onclick="<% if(n.project_id){ %>location.href='/projects/<%= n.project_id %>'<% } %>">
              <div class="notif-content">
                <div class="notif-title" style="font-size:0.85rem"><%= n.title || '📢 Thông báo' %></div>
                <div class="notif-msg" style="font-size:0.8rem"><%= n.message.substring(0,80) %><%= n.message.length>80?'...':'' %></div>
                <div class="notif-time"><%= new Date(n.created_at).toLocaleString('vi-VN') %></div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
